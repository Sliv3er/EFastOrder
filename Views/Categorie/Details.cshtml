@model Categorie
@{
    ViewData["Title"] = Model.Nom;
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-info-circle text-warning me-2"></i>@Model.Nom</h1>
        <div class="breadcrumb-custom">
            <a asp-action="Index">Catégories</a><span class="mx-2">/</span><span>Détails</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="form-card text-center">
        <div style="width: 90px; height: 90px; border-radius: 50%; background: rgba(255,109,0,0.1); display: inline-flex; align-items: center; justify-content: center; font-size: 2.5rem; margin-bottom: 1rem;">
            <i class="@(Model.Icone ?? "fas fa-tag")" style="color: var(--primary-light);"></i>
        </div>
        <h3>@Model.Nom</h3>
        <p class="text-muted">@(Model.Description ?? "Aucune description")</p>
        <p class="mt-2"><small class="text-muted">Icône: <code>@(Model.Icone ?? "non définie")</code></small></p>
        <div class="d-flex gap-2 justify-content-center mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom"><i class="fas fa-edit"></i> Modifier</a>
            <a asp-action="Index" class="btn-outline-custom"><i class="fas fa-arrow-left"></i> Retour</a>
        </div>
    </div>
</div>
