@model Categorie
@{
    ViewData["Title"] = "Nouvelle Catégorie";
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-plus-circle text-warning me-2"></i>Nouvelle Catégorie</h1>
        <div class="breadcrumb-custom">
            <a asp-action="Index">Catégories</a><span class="mx-2">/</span><span>Créer</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="form-card">
        <p class="text-muted mb-3" style="font-size: 0.8rem;"><i class="fas fa-code me-1"></i> Opération ADO.NET : INSERT</p>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nom" class="form-label"></label>
                <input asp-for="Nom" class="form-control" placeholder="Ex: Entrées, Desserts..." />
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Description de la catégorie..."></textarea>
            </div>

            <div class="mb-4">
                <label asp-for="Icone" class="form-label"></label>
                <input asp-for="Icone" class="form-control" placeholder="fas fa-pizza-slice" />
                <small class="text-muted">Classe Font Awesome (ex: fas fa-utensils, fas fa-ice-cream)</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-custom"><i class="fas fa-save"></i> Créer</button>
                <a asp-action="Index" class="btn-outline-custom"><i class="fas fa-arrow-left"></i> Retour</a>
            </div>
        </form>
    </div>
</div>
