@model IEnumerable<Commande>
@{
    ViewData["Title"] = "Toutes les Commandes";
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-clipboard-list text-warning me-2"></i>Toutes les Commandes</h1>
        <div class="breadcrumb-custom">
            <a asp-controller="Dashboard" asp-action="Index">Dashboard</a><span class="mx-2">/</span><span>Commandes</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="table-custom">
        <table class="table">
            <thead>
                <tr>
                    <th>N° Commande</th>
                    <th>Date</th>
                    <th>Client</th>
                    <th>Articles</th>
                    <th>Total</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cmd in Model)
                {
                    <tr>
                        <td><strong class="text-warning">@cmd.NumeroCommande</strong></td>
                        <td>@cmd.DateCommande.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><small>@cmd.UserId</small></td>
                        <td>@(cmd.Items?.Count ?? 0)</td>
                        <td><strong>@cmd.MontantTotal.ToString("N2") DT</strong></td>
                        <td>
                            @{
                                var bc = cmd.Statut switch
                                {
                                    StatutCommande.EnAttente => "badge-en-attente",
                                    StatutCommande.EnPreparation => "badge-en-preparation",
                                    StatutCommande.Prete => "badge-prete",
                                    StatutCommande.Livree => "badge-livree",
                                    StatutCommande.Annulee => "badge-annulee",
                                    _ => "badge-en-attente"
                                };
                            }
                            <span class="badge badge-status @bc">@cmd.Statut</span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@cmd.Id" class="btn btn-sm btn-outline-info" title="Détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (cmd.Statut != StatutCommande.Annulee && cmd.Statut != StatutCommande.Livree)
                                {
                                    <form asp-action="ChangerStatut" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@cmd.Id" />
                                        @{
                                            var nextStatus = cmd.Statut switch
                                            {
                                                StatutCommande.EnAttente => StatutCommande.EnPreparation,
                                                StatutCommande.EnPreparation => StatutCommande.Prete,
                                                StatutCommande.Prete => StatutCommande.Livree,
                                                _ => StatutCommande.Livree
                                            };
                                        }
                                        <input type="hidden" name="statut" value="@nextStatus" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Avancer le statut">
                                            <i class="fas fa-forward"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
