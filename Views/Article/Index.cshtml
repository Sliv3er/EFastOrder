@model IEnumerable<Article>
@{
    ViewData["Title"] = "Gestion des Articles";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="page-title"><i class="fas fa-utensils text-warning me-2"></i>Gestion des Articles</h1>
                <div class="breadcrumb-custom">
                    <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <span class="mx-2">/</span>
                    <span>Articles</span>
                </div>
            </div>
            <a asp-action="Create" class="btn-primary-custom">
                <i class="fas fa-plus"></i> Nouvel Article
            </a>
        </div>
    </div>
</div>

<div class="container">
    <p class="text-muted mb-3"><i class="fas fa-database me-1"></i> CRUD réalisé avec <strong>Entity Framework</strong></p>
    
    <div class="table-custom">
        <table class="table">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Catégorie</th>
                    <th>Prix</th>
                    <th>Temps</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in Model)
                {
                    <tr>
                        <td>
                            <strong>@article.Nom</strong>
                            <br /><small class="text-muted">@(article.Description?.Length > 50 ? article.Description.Substring(0, 50) + "..." : article.Description)</small>
                        </td>
                        <td>
                            <span class="badge" style="background: rgba(255,109,0,0.15); color: var(--primary-light);">
                                <i class="@(article.Categorie?.Icone ?? "fas fa-tag") me-1"></i>
                                @article.Categorie?.Nom
                            </span>
                        </td>
                        <td><strong class="text-warning">@article.Prix.ToString("N2") DT</strong></td>
                        <td>@(article.TempPreparation.HasValue ? article.TempPreparation + " min" : "-")</td>
                        <td>
                            @if (article.IsDisponible)
                            {
                                <span class="badge badge-status badge-prete">Disponible</span>
                            }
                            else
                            {
                                <span class="badge badge-status badge-annulee">Indisponible</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-sm btn-outline-warning me-1" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@article.Id" class="btn btn-sm btn-outline-info me-1" title="Détails">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@article.Id" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
