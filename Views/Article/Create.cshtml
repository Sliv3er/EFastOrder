@model Article
@{
    ViewData["Title"] = "Nouvel Article";
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-plus-circle text-warning me-2"></i>Nouvel Article</h1>
        <div class="breadcrumb-custom">
            <a asp-controller="Article" asp-action="Index">Articles</a>
            <span class="mx-2">/</span>
            <span>Créer</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nom" class="form-label"></label>
                <input asp-for="Nom" class="form-control" placeholder="Ex: Pizza Margherita" />
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Description du plat..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Prix" class="form-label"></label>
                    <input asp-for="Prix" class="form-control" type="number" step="0.01" placeholder="12.50" />
                    <span asp-validation-for="Prix" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TempPreparation" class="form-label"></label>
                    <input asp-for="TempPreparation" class="form-control" type="number" placeholder="15" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategorieId" class="form-label"></label>
                <select asp-for="CategorieId" asp-items="@(ViewBag.Categories as SelectList)" class="form-select">
                    <option value="">-- Sélectionner une catégorie --</option>
                </select>
                <span asp-validation-for="CategorieId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="/images/articles/mon-plat.jpg" />
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="IsDisponible" class="form-check-input" />
                    <label asp-for="IsDisponible" class="form-check-label">Article disponible</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-custom">
                    <i class="fas fa-save"></i> Créer l'article
                </button>
                <a asp-action="Index" class="btn-outline-custom">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
        </form>
    </div>
</div>
