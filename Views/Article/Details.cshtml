@model Article
@{
    ViewData["Title"] = Model.Nom;
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-eye text-warning me-2"></i>@Model.Nom</h1>
        <div class="breadcrumb-custom">
            <a asp-controller="Article" asp-action="Index">Articles</a>
            <span class="mx-2">/</span>
            <span>Détails</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="form-card" style="max-width: 700px;">
        <div class="text-center mb-4">
            <div style="width: 120px; height: 120px; margin: 0 auto; border-radius: 16px; background: rgba(255,109,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 3rem;">
                <i class="@(Model.Categorie?.Icone ?? "fas fa-utensils")" style="color: var(--primary-light);"></i>
            </div>
        </div>

        <h3 class="text-center mb-1">@Model.Nom</h3>
        <p class="text-center text-muted mb-4">@Model.Description</p>

        <div class="row g-3">
            <div class="col-6">
                <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border);">
                    <small class="text-muted d-block">Prix</small>
                    <strong class="text-warning" style="font-size: 1.3rem;">@Model.Prix.ToString("N2") DT</strong>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border);">
                    <small class="text-muted d-block">Catégorie</small>
                    <strong><i class="@(Model.Categorie?.Icone ?? "fas fa-tag") me-1"></i>@Model.Categorie?.Nom</strong>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border);">
                    <small class="text-muted d-block">Temps de préparation</small>
                    <strong><i class="far fa-clock me-1"></i>@(Model.TempPreparation.HasValue ? Model.TempPreparation + " minutes" : "Non spécifié")</strong>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border);">
                    <small class="text-muted d-block">Disponibilité</small>
                    @if (Model.IsDisponible)
                    {
                        <span class="badge badge-status badge-prete">Disponible</span>
                    }
                    else
                    {
                        <span class="badge badge-status badge-annulee">Indisponible</span>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 justify-content-center">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom">
                <i class="fas fa-edit"></i> Modifier
            </a>
            <a asp-action="Index" class="btn-outline-custom">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>
