@model Article
@{
    ViewData["Title"] = "Supprimer " + Model.Nom;
}

<div class="container" style="padding-top: 2rem;">
    <div class="delete-card">
        <div class="delete-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h4>Confirmer la suppression</h4>
        <p class="text-muted mt-3"> tes-vous s˚r de vouloir supprimer l'article suivant ?</p>
        <div class="p-3 my-3 rounded" style="background: rgba(255,23,68,0.05); border: 1px solid rgba(255,23,68,0.2);">
            <h5 class="mb-1">@Model.Nom</h5>
            <small class="text-muted">@Model.Categorie?.Nom ï @Model.Prix.ToString("N2") DT</small>
        </div>
        <p class="text-danger" style="font-size: 0.85rem;">?? Cette action est irrÈversible.</p>

        <div class="d-flex gap-2 justify-content-center mt-4">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-primary-custom" style="background: var(--danger);">
                    <i class="fas fa-trash"></i> Supprimer
                </button>
            </form>
            <a asp-action="Index" class="btn-outline-custom">
                <i class="fas fa-arrow-left"></i> Annuler
            </a>
        </div>
    </div>
</div>
