@model PanierViewModel
@{
    ViewData["Title"] = "Mon Panier";
}

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-shopping-cart text-warning me-2"></i>Mon Panier</h1>
        <div class="breadcrumb-custom">
            <a asp-controller="Home" asp-action="Index">Menu</a>
            <span class="mx-2">/</span>
            <span>Panier</span>
        </div>
    </div>
</div>

<div class="container">
    @if (Model.Panier?.Items != null && Model.Panier.Items.Any())
    {
        <div class="row">
            <!-- Cart Items -->
            <div class="col-lg-8">
                @foreach (var item in Model.Panier.Items)
                {
                    <div class="cart-item animate__animated animate__fadeInLeft">
                        <div class="cart-item-img">
                            @if (!string.IsNullOrEmpty(item.Article?.ImageUrl))
                            {
                                <img src="@item.Article.ImageUrl" alt="@item.Article?.Nom" />
                            }
                            else
                            {
                                <i class="@(item.Article?.Categorie?.Icone ?? "fas fa-utensils")"></i>
                            }
                        </div>
                        <div class="cart-item-info">
                            <h6 class="cart-item-title">@item.Article?.Nom</h6>
                            <span class="cart-item-category">@item.Article?.Categorie?.Nom</span>
                        </div>
                        <div class="text-center">
                            <div class="quantity-control">
                                <form asp-action="ModifierQuantite" method="post" style="display:inline;">
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <input type="hidden" name="quantite" value="@(item.Quantite - 1)" />
                                    <button type="submit" class="quantity-btn"><i class="fas fa-minus"></i></button>
                                </form>
                                <span class="quantity-value">@item.Quantite</span>
                                <form asp-action="ModifierQuantite" method="post" style="display:inline;">
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <input type="hidden" name="quantite" value="@(item.Quantite + 1)" />
                                    <button type="submit" class="quantity-btn"><i class="fas fa-plus"></i></button>
                                </form>
                            </div>
                        </div>
                        <div class="text-end" style="min-width: 90px;">
                            <div class="cart-item-price">@item.SousTotal.ToString("N2") DT</div>
                            <small class="text-muted">@item.PrixUnitaire.ToString("N2") DT /u</small>
                        </div>
                        <form asp-action="Retirer" method="post">
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" 
                                    style="width:36px; height:36px;" title="Retirer">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>
                    </div>
                }

                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn-outline-custom">
                        <i class="fas fa-arrow-left"></i> Continuer les achats
                    </a>
                    <form asp-action="Vider" method="post">
                        <button type="submit" class="btn-outline-custom" style="border-color: var(--danger); color: var(--danger);"
                                onclick="return confirm('Voulez-vous vraiment vider le panier ?')">
                            <i class="fas fa-trash"></i> Vider le panier
                        </button>
                    </form>
                </div>
            </div>

            <!-- Cart Summary -->
            <div class="col-lg-4">
                <div class="cart-summary animate__animated animate__fadeInRight">
                    <h5 class="cart-summary-title"><i class="fas fa-receipt me-2"></i>Récapitulatif</h5>
                    
                    @foreach (var item in Model.Panier.Items)
                    {
                        <div class="cart-summary-row">
                            <span class="text-muted">@item.Article?.Nom x@item.Quantite</span>
                            <span>@item.SousTotal.ToString("N2") DT</span>
                        </div>
                    }

                    <div class="cart-summary-total">
                        <span>Total</span>
                        <span>@Model.Total.ToString("N2") DT</span>
                    </div>

                    <a asp-controller="Commande" asp-action="Passer" class="btn-primary-custom w-100 justify-content-center mt-4"
                       style="padding: 0.85rem; font-size: 1rem;">
                        <i class="fas fa-check-circle"></i> Passer la commande
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state animate__animated animate__fadeIn">
            <i class="fas fa-shopping-cart"></i>
            <h4>Votre panier est vide</h4>
            <p>Parcourez notre menu et ajoutez des articles ŕ votre panier.</p>
            <a asp-controller="Home" asp-action="Index" class="btn-primary-custom mt-3">
                <i class="fas fa-utensils"></i> Découvrir le menu
            </a>
        </div>
    }
</div>
